generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Complaint {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String
  category    String
  priority    String   @default("Medium")
  status      String   @default("Submitted")
  mode        String   @default("Public")
  assignedTo  String?
  slaDeadline DateTime
  timeline    String   // Store serialized JSON string of timeline objects
  feedback    String?  // Store serialized JSON of {rating: number, comment: string}
  attachment  String?  // Store relative URL of uploaded image (e.g. /uploads/1234.png)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
